<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://liquibase.org"
        xmlns:xsi="http://w3.org"
        xsi:schemaLocation="http://liquibase.org
        http://liquibase.org/dbchangelog-3.8.xsd">

    <changeSet id="create_currency_table" author="skillbox">
        <createTable tableName="currency">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar(255)"/>
            <column name="nominal" type="bigint"/>
            <column name="value" type="numeric(19,5)"/>
            <column name="iso_num_code" type="bigint"/>
        </createTable>
    </changeSet>

</databaseChangeLog>